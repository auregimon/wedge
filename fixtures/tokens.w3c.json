{
  "color": {
    "brand":  { "$value": "#2563EB", "$type": "color" },
    "ink":    { "$value": "#0F172A", "$type": "color" },
    "paper":  { "$value": "#FFFFFF", "$type": "color" },
    "slate":  { "500": { "$value": "#64748B", "$type": "color" } },
    "red":    { "600": { "$value": "#DC2626", "$type": "color" } },
    "green":  { "600": { "$value": "#16A34A", "$type": "color" } },
    "danger":  { "$value": "{color.red.600}",   "$type": "color" },
    "success": { "$value": "{color.green.600}", "$type": "color" }
  },
  "space": {
    "1": { "$value": "4px",  "$type": "dimension" },
    "2": { "$value": "8px",  "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "5": { "$value": "24px", "$type": "dimension" },
    "6": { "$value": "32px", "$type": "dimension" }
  },
  "font": {
    "size": {
      "xs":  { "$value": "12px", "$type": "dimension" },
      "sm":  { "$value": "14px", "$type": "dimension" },
      "md":  { "$value": "16px", "$type": "dimension" },
      "lg":  { "$value": "20px", "$type": "dimension" },
      "xl":  { "$value": "25px", "$type": "dimension" },
      "xxl": { "$value": "31px", "$type": "dimension" }
    }
  }
}
